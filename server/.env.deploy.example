# 生产部署环境变量（由 deploy.ps1 首次部署时复制为 .env）
# 开发环境默认 3000，生产环境建议使用 8080

PORT=8080
HOST=0.0.0.0
PUBLIC_BASE_URL=http://10.10.114.246:8080

FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_REDIRECT_URI=http://10.10.114.246:8080/api/auth/feishu/callback

JWT_SECRET=change_me_to_a_long_random_string
COOKIE_SECRET=change_me_cookie_secret

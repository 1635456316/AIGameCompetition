# 生产部署环境变量（由 deploy.ps1 首次部署时复制为 .env）
# 开发环境默认 3000，生产环境建议使用 8081（8080 常被 Jenkins 占用）

PORT=8081
HOST=0.0.0.0
PUBLIC_BASE_URL=http://10.10.114.246:8081

FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_REDIRECT_URI=http://10.10.114.246:8081/api/auth/feishu/callback

JWT_SECRET=change_me_to_a_long_random_string
COOKIE_SECRET=change_me_cookie_secret

# 经 Nginx 等反向代理部署时保持默认即可（trustProxy 开启），以便正确识别客户端 IP（用户名登录绑定）
# 本地直连调试且无代理时可设 TRUST_PROXY=false
